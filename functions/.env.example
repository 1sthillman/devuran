# Firebase Functions Environment Variables
# 
# NOT USED IN PRODUCTION!
# Bu dosya sadece local emulator için.
# Production'da Firebase Functions config kullan:
# firebase functions:config:set key=value

# Google OAuth (Local emulator only)
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_REDIRECT_URI=http://localhost:5001/your-project/europe-west1/api/v1/google/oauth/callback

# Encryption (Local emulator only)
ENCRYPTION_KEY=your-32-byte-base64-encryption-key

# Redis (Optional - Local emulator only)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Feature Flags
GOOGLE_INTEGRATION_ENABLED=true
REDIS_ENABLED=false

# Environment
NODE_ENV=development
