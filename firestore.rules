rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isSalonOwner(salonId) {
      return isAuthenticated() && 
             exists(/databases/$(database)/documents/salons/$(salonId)) &&
             get(/databases/$(database)/documents/salons/$(salonId)).data.ownerId == request.auth.uid;
    }
    
    function isAdmin() {
      return isAuthenticated() && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Users collection
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    // Salons collection
    match /salons/{salonId} {
      allow read: if true; // Public read
      allow create: if isAuthenticated();
      allow update: if isSalonOwner(salonId) || isAdmin();
      allow delete: if isSalonOwner(salonId) || isAdmin();
    }

    // Services collection
    match /services/{serviceId} {
      allow read: if true; // Public read
      allow write: if isAuthenticated() && 
                      isSalonOwner(resource.data.salonId);
    }

    // Staff collection
    match /staff/{staffId} {
      allow read: if true; // Public read
      allow write: if isAuthenticated() && 
                      isSalonOwner(resource.data.salonId);
    }

    // Reservations collection - NEW
    match /reservations/{reservationId} {
      // Read: Owner of reservation or business owner
      allow read: if isAuthenticated() && (
        isOwner(resource.data.userId) || 
        isSalonOwner(resource.data.businessId) ||
        isAdmin()
      );
      
      // Create: Any authenticated user
      allow create: if isAuthenticated() && 
                       isOwner(request.resource.data.userId);
      
      // Update: Business owner can update status, user can cancel
      allow update: if isAuthenticated() && (
        (isSalonOwner(resource.data.businessId) && 
         request.resource.data.diff(resource.data).affectedKeys()
           .hasOnly(['status', 'updatedAt', 'pricing', 'internalNotes'])) ||
        (isOwner(resource.data.userId) && 
         request.resource.data.diff(resource.data).affectedKeys()
           .hasOnly(['status', 'updatedAt', 'notes']) &&
         request.resource.data.status in ['cancelled_by_user'])
      );
      
      // Delete: Only admin
      allow delete: if isAdmin();
    }

    // Appointments collection (old system - keep for backward compatibility)
    match /appointments/{appointmentId} {
      allow read: if isAuthenticated() && (
        isOwner(resource.data.userId) || 
        isSalonOwner(resource.data.salonId) ||
        isAdmin()
      );
      allow create: if isAuthenticated() && isOwner(request.resource.data.userId);
      allow update: if isAuthenticated() && (
        isSalonOwner(resource.data.salonId) || 
        isOwner(resource.data.userId)
      );
      allow delete: if isSalonOwner(resource.data.salonId) || isAdmin();
    }

    // Queue collection
    match /queue/{queueId} {
      allow read: if isAuthenticated() && (
        isOwner(resource.data.userId) || 
        isSalonOwner(resource.data.salonId) ||
        isAdmin()
      );
      allow create: if isAuthenticated() && isOwner(request.resource.data.userId);
      allow update: if isSalonOwner(resource.data.salonId);
      allow delete: if isAuthenticated() && (
        isOwner(resource.data.userId) || 
        isSalonOwner(resource.data.salonId) ||
        isAdmin()
      );
    }

    // Reviews collection
    match /reviews/{reviewId} {
      allow read: if true; // Public read
      allow create: if isAuthenticated() && isOwner(request.resource.data.userId);
      allow update: if isAuthenticated() && (
        isOwner(resource.data.userId) || 
        isSalonOwner(resource.data.salonId)
      );
      allow delete: if isAdmin();
    }

    // Banned users collection
    match /bannedUsers/{banId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && isSalonOwner(request.resource.data.salonId);
    }

    // Customer ratings collection
    match /salonCustomerRatings/{ratingId} {
      allow read: if isAuthenticated() && isSalonOwner(resource.data.salonId);
      allow write: if isAuthenticated() && isSalonOwner(request.resource.data.salonId);
    }

    // Default deny all other collections
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
