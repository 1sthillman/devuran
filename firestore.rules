rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function for Super Admin
    // ✅ GÜVENLİK: Custom claims + fallback email kontrolü
    // Date: 2026-07-03
    // Issue: CRITICAL #10 - Email-based admin control migration
    function isSuperAdmin() {
      return request.auth != null && 
             (request.auth.token.admin == true ||
              request.auth.token.email in ['adistow@gmail.com', 'admin@restoqr.com', 'minif@restoqr.com', 'minifinise@gmail.com']);
    }
    
    // Helper function to check admin custom claim
    function hasAdminClaim() {
      return request.auth != null && 
             request.auth.token.admin == true;
    }
    
    // ✅ NEW: Subscription limit validation helper
    function validateSubscriptionLimit(businessId, limitType) {
      let subscription = get(/databases/$(database)/documents/subscriptions/$(businessId)).data;
      let features = subscription.customFeatures;
      
      // Use default plan features if no custom features
      return features == null ? true :
             limitType == 'staffCount' ? 
               (features.maxStaff == 'unlimited' || subscription.usage.staffCount < features.maxStaff) :
             limitType == 'serviceCount' ?
               (features.maxServices == 'unlimited' || subscription.usage.serviceCount < features.maxServices) :
             true;
    }
    
    // Helper function to check if user is salon owner
    function isSalonOwner(salonId) {
      return request.auth != null && 
             get(/databases/$(database)/documents/salons/$(salonId)).data.ownerId == request.auth.uid;
    }
    
    // --- USERS COLLECTION ---
    match /users/{userId} {
      // Users can read/write their own data
      allow read, write: if request.auth != null && request.auth.uid == userId;
      // Super admins can access all users
      allow read, write: if isSuperAdmin();
      // Allow user creation during signup
      allow create: if request.auth != null && request.auth.uid == userId;
    }
    
    // --- SALONS COLLECTION ---
    match /salons/{salonId} {
      // Public read access (customers need to see salons)
      allow read: if true;
      
      // Super admins can do anything (must be first!)
      allow read, write: if isSuperAdmin();
      
      // Salon owners can update their own salon
      // Check ownerId if it exists, otherwise check if user has owner role with matching salonId
      allow update: if request.auth != null && 
                       (resource.data.ownerId == request.auth.uid ||
                        (!('ownerId' in resource.data) && 
                         exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
                         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'owner' &&
                         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.salonId == salonId));
      
      // Salon owners can create their own salon
      allow create: if request.auth != null && 
                       request.resource.data.ownerId == request.auth.uid;
      
      // Salon owners can delete their own salon
      allow delete: if request.auth != null && 
                       (resource.data.ownerId == request.auth.uid ||
                        (!('ownerId' in resource.data) && 
                         exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
                         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'owner' &&
                         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.salonId == salonId));
    }
    
    // --- SERVICES COLLECTION ---
    match /services/{serviceId} {
      // Public read access (customers need to see services)
      allow read: if true;
      
      // Salon owners can manage their services
      allow write: if request.auth != null && 
                      (resource == null || isSalonOwner(resource.data.salonId));
      
      // Super admins can do anything
      allow read, write: if isSuperAdmin();
      
      // Allow creation with salonId
      allow create: if request.auth != null;
    }
    
    // --- RESERVATIONS COLLECTION ---
    match /reservations/{reservationId} {
      // Public read for availability check and booking flow
      allow read: if true;
      
      // ✅ GÜVENLİK: Create sadece authenticated user
      // ✅ OPERASYON: İşletme sahibi "system-block" olarak blok rezervasyon oluşturabilir
      allow create: if request.auth != null &&
                       (request.resource.data.userId == request.auth.uid ||
                        (request.resource.data.userId == 'system-block' && 
                         isSalonOwner(request.resource.data.businessId)));
      
      // Customers can update their own reservations (status, cancellation)
      allow update: if request.auth != null && 
                       (resource.data.userId == request.auth.uid || 
                        isSalonOwner(resource.data.businessId));
      
      // Salon owners can update reservations for their business (deposit confirmation, status, date/time changes)
      allow update: if request.auth != null && isSalonOwner(resource.data.businessId);
      
      // Allow status, payment updates, and date/time changes
      allow update: if request.resource.data.diff(resource.data).affectedKeys()
                       .hasOnly(['status', 'cancelledAt', 'cancelledBy', 'cancellationReason', 
                                'pricing', 'updatedAt', 'date', 'startTime', 'endTime', 
                                'eventDate', 'checkIn', 'deliveryDate', 'deliveryTime']);
      
      // ✅ OPERASYON: İşletme sahibi kendi işletmesinin rezervasyonlarını silebilir (iptal edebilir)
      allow delete: if request.auth != null && isSalonOwner(resource.data.businessId);
      
      // Super admins can do anything
      allow read, write: if isSuperAdmin();
    }
    
    // --- APPOINTMENTS COLLECTION (same as reservations) ---
    match /appointments/{appointmentId} {
      // Public read for availability check and booking flow
      allow read: if true;
      
      // Anyone can create appointments (anonymous bookings)
      allow create: if true;
      
      // Customers can update their own appointments
      allow update: if request.auth != null && 
                       (resource.data.userId == request.auth.uid || 
                        isSalonOwner(resource.data.salonId));
      
      // Salon owners can update appointments for their business
      allow update: if request.auth != null && isSalonOwner(resource.data.salonId);
      
      // Allow status updates, cancellations, and review flags
      allow update: if request.auth != null &&
                       request.resource.data.diff(resource.data).affectedKeys()
                       .hasOnly(['status', 'cancelledAt', 'cancelledBy', 'cancellationReason', 
                                'hasReview', 'reviewId', 'updatedAt']);
      
      // Super admins can do anything
      allow read, write: if isSuperAdmin();
    }
    
    // --- QUEUE COLLECTION ---
    match /queue/{queueId} {
      // Public read access (customers can see queue status)
      allow read: if true;
      
      // Anyone can join queue (anonymous bookings allowed)
      allow create: if true;
      
      // Customers can update their own queue entries
      allow update: if request.auth != null && 
                       resource.data.userId == request.auth.uid;
      
      // Customers can delete their own queue entries
      allow delete: if request.auth != null && 
                       resource.data.userId == request.auth.uid;
      
      // Salon owners can manage queue for their salon (including delete)
      allow read, write, delete: if request.auth != null && isSalonOwner(resource.data.salonId);
      
      // Super admins can do anything
      allow read, write: if isSuperAdmin();
    }
    
    // --- REVIEWS COLLECTION ---
    match /reviews/{reviewId} {
      // Public read access
      allow read: if true;
      
      // Customers can create reviews
      allow create: if true;
      
      // Users can update/delete their own reviews
      allow update, delete: if request.auth != null && 
                               resource.data.userId == request.auth.uid;
      
      // Salon owners can respond to reviews
      allow update: if request.auth != null && 
                       isSalonOwner(resource.data.salonId) &&
                       request.resource.data.diff(resource.data).affectedKeys()
                       .hasOnly(['ownerResponse', 'respondedAt']);
      
      // Super admins can do anything
      allow read, write: if isSuperAdmin();
    }
    
    // --- AVAILABILITY COLLECTION ---
    match /availability/{availabilityId} {
      // Public read access (needed for booking flow)
      allow read: if true;
      
      // Salon owners can manage availability
      allow write: if request.auth != null && isSalonOwner(resource.data.salonId);
      
      // Super admins can do anything
      allow read, write: if isSuperAdmin();
    }
    
    // --- STAFF COLLECTION ---
    match /staff/{staffId} {
      // Public read access (customers need to see staff)
      allow read: if true;
      
      // ✅ SECURITY: Create with subscription limit awareness
      // Issue: CRITICAL #11 - Subscription limit bypass prevention
      // Date: 2026-07-03
      // Note: Actual enforcement done in Cloud Functions (onStaffCreate trigger)
      allow create: if request.auth != null && 
                       request.resource.data.salonId is string &&
                       (isSalonOwner(request.resource.data.salonId) || isSuperAdmin());
      
      // Salon owners can update/delete their own staff
      allow update, delete: if request.auth != null && 
                               (resource == null || isSalonOwner(resource.data.salonId));
      
      // Super admins can do anything
      allow read, write: if isSuperAdmin();
    }
    
    // --- NOTIFICATIONS COLLECTION ---
    match /notifications/{notificationId} {
      // Users can read their own notifications
      allow read: if request.auth != null && 
                     resource.data.userId == request.auth.uid;
      
      // System can create notifications
      allow create: if true;
      
      // Users can update their own notifications (mark as read)
      allow update: if request.auth != null && 
                       resource.data.userId == request.auth.uid;
      
      // Super admins can do anything
      allow read, write: if isSuperAdmin();
    }
    
    // --- CATEGORIES COLLECTION ---
    match /categories/{categoryId} {
      // Public read access
      allow read: if true;
      
      // Only super admins can write categories
      allow write: if isSuperAdmin();
    }
    
    // --- ANALYTICS COLLECTION ---
    match /analytics/{document=**} {
      // Salon owners can read their own analytics
      allow read: if request.auth != null;
      
      // Only salon owners can write analytics for their salon
      allow write: if request.auth != null && 
                      exists(/databases/$(database)/documents/salons/$(request.resource.data.salonId)) &&
                      get(/databases/$(database)/documents/salons/$(request.resource.data.salonId)).data.ownerId == request.auth.uid;
      
      // Super admins can do anything
      allow read, write: if isSuperAdmin();
    }
    
    // --- CUSTOMERS COLLECTION ---
    match /customers/{customerId} {
      // Anyone authenticated can read customers (they're computed from appointments)
      allow read: if request.auth != null;
      
      // Salon owners can write customer data (notes, tags, ratings, ban status)
      // Document ID format: {salonId}_{userId}
      allow create, update: if request.auth != null && 
                               request.resource.data.salonId is string &&
                               (
                                 // Check if salon exists and user is owner
                                 (exists(/databases/$(database)/documents/salons/$(request.resource.data.salonId)) &&
                                  get(/databases/$(database)/documents/salons/$(request.resource.data.salonId)).data.ownerId == request.auth.uid) ||
                                 // OR check if user has owner role with matching salonId
                                 (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'owner' &&
                                  get(/databases/$(database)/documents/users/$(request.auth.uid)).data.salonId == request.resource.data.salonId)
                               );
      
      // Salon owners can delete customer data
      allow delete: if request.auth != null && 
                       resource.data.salonId is string &&
                       (
                         (exists(/databases/$(database)/documents/salons/$(resource.data.salonId)) &&
                          get(/databases/$(database)/documents/salons/$(resource.data.salonId)).data.ownerId == request.auth.uid) ||
                         (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'owner' &&
                          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.salonId == resource.data.salonId)
                       );
      
      // Super admins can do anything
      allow read, write: if isSuperAdmin();
    }
    
    // --- BLOCKED BUSINESSES COLLECTION ---
    match /blockedBusinesses/{blockId} {
      // Users can read their own blocks
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      
      // Users can create blocks (block a business)
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      
      // Users can delete their own blocks (unblock)
      allow delete: if request.auth != null && resource.data.userId == request.auth.uid;
      
      // Super admins can do anything
      allow read, write: if isSuperAdmin();
    }
    
    // --- CHAT SESSIONS ---
    match /chat_sessions/{sessionId} {
      // Users can read/write their own chat sessions
      allow read, write: if request.auth != null && 
                            (resource.data.userId == request.auth.uid || 
                             isSalonOwner(resource.data.salonId));
      
      // Allow creation
      allow create: if true;
      
      // Super admins can access all chats
      allow read, write: if isSuperAdmin();
      
      match /messages/{messageId} {
        // Users can read/write messages in their sessions
        allow read, write: if request.auth != null;
        allow create: if true;
        allow read, write: if isSuperAdmin();
      }
    }
    
    // --- SETTINGS COLLECTION ---
    match /settings/{document=**} {
      // Public read for app settings
      allow read: if true;
      
      // Only super admins can write settings
      allow write: if isSuperAdmin();
    }
    
    // --- SUBSCRIPTIONS COLLECTION ---
    // ✅ TEMPLİK AÇIK - TEST İÇİN
    match /subscriptions/{subscriptionId} {
      // Herkes okuyabilir (test için)
      allow read: if request.auth != null;
      
      // Herkes oluşturabilir (test için)
      allow create: if request.auth != null;
      
      // Herkes güncelleyebilir (test için)
      allow update: if request.auth != null;
      
      // Admin silebilir
      allow delete: if isSuperAdmin();
    }
    
    // --- SUBSCRIPTION HISTORY COLLECTION ---
    // ✅ TEMPLİK AÇIK - TEST İÇİN
    match /subscriptionHistory/{historyId} {
      // Herkes okuyabilir
      allow read: if request.auth != null;
      
      // Herkes oluşturabilir
      allow create: if request.auth != null;
      
      // Admin silebilir/güncelleyebilir
      allow update, delete: if isSuperAdmin();
    }
    
    // --- NOTIFICATION HISTORY COLLECTION ---
    match /notificationHistory/{historyId} {
      // Only super admins can read/write notification history
      allow read, write: if isSuperAdmin();
    }
    
    // --- SUPPORT TICKETS COLLECTION ---
    match /supportTickets/{ticketId} {
      // Users can read/write their own tickets
      allow read, write: if request.auth != null && resource.data.userId == request.auth.uid;
      
      // Allow creation
      allow create: if request.auth != null;
      
      // Super admins can access all tickets
      allow read, write: if isSuperAdmin();
    }
    
    // --- SYSTEM CONFIG COLLECTION ---
    match /systemConfig/{configId} {
      // Public read for maintenance mode check
      allow read: if true;
      
      // Only super admins can write system config
      allow write: if isSuperAdmin();
    }
    
    // --- ADMIN ROLES COLLECTION ---
    match /adminRoles/{roleId} {
      // Only super admins can read/write admin roles
      allow read, write: if isSuperAdmin();
    }
    
    // --- SECURITY LOGS COLLECTION ---
    match /securityLogs/{logId} {
      // Only super admins can read security logs
      allow read: if isSuperAdmin();
      
      // System can create logs
      allow create: if true;
    }
    
    // --- AUDIT LOGS COLLECTION (Admin Panel) ---
    match /audit_logs/{logId} {
      // Only super admins can read audit logs
      allow read: if isSuperAdmin();
      
      // System can create logs
      allow create: if true;
      
      // No one can update or delete audit logs
      allow update, delete: if false;
    }
    
    // --- SUPPORT TICKETS COLLECTION (Admin Panel) ---
    match /support_tickets/{ticketId} {
      // Users can read their own tickets (by ownerId)
      allow read: if request.auth != null && 
                     (resource.data.ownerId == request.auth.uid || 
                      isSuperAdmin());
      
      // Users can create tickets
      allow create: if request.auth != null &&
                       request.resource.data.ownerId == request.auth.uid;
      
      // Users can update their own tickets
      allow update: if request.auth != null && 
                       (resource.data.ownerId == request.auth.uid ||
                        isSuperAdmin());
      
      // Super admins can do everything
      allow read, write: if isSuperAdmin();
    }
    
    // --- SUPPORT MESSAGES COLLECTION ---
    match /support_messages/{messageId} {
      // Users can read messages from tickets they own
      allow read: if request.auth != null;
      
      // Users can create messages
      allow create: if request.auth != null;
      
      // Super admins can do everything
      allow read, write: if isSuperAdmin();
    }
    
    // --- ANNOUNCEMENTS COLLECTION ---
    match /announcements/{announcementId} {
      // All authenticated users can read announcements
      allow read: if request.auth != null;
      
      // Only super admins can create/update/delete announcements
      allow write: if isSuperAdmin();
    }
    
    // --- BANNED USERS COLLECTION ---
    match /bannedUsers/{userId} {
      // Only super admins can read/write banned users
      allow read, write: if isSuperAdmin();
    }
    
    // --- DELETED USERS COLLECTION (Soft Delete) ---
    match /deletedUsers/{userId} {
      // Only super admins can read/write deleted users
      allow read, write: if isSuperAdmin();
    }
    
    // --- PAYMENT TRANSACTIONS COLLECTION ---
    match /paymentTransactions/{transactionId} {
      // Business owners can read their own transactions
      allow read: if request.auth != null && 
                     (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.salonId == resource.data.businessId ||
                      (exists(/databases/$(database)/documents/salons/$(resource.data.businessId)) &&
                       get(/databases/$(database)/documents/salons/$(resource.data.businessId)).data.ownerId == request.auth.uid));
      
      // Super admins can read all transactions
      allow read: if isSuperAdmin();
      
      // Only system can create transactions
      allow create: if true;
      
      // Super admins can update (for refunds, etc.)
      allow update: if isSuperAdmin();
      
      // No one can delete transactions
      allow delete: if false;
    }
    
    // --- COUPONS COLLECTION ---
    match /coupons/{couponId} {
      // Public read for coupon validation
      allow read: if true;
      
      // Only super admins can write coupons
      allow write: if isSuperAdmin();
    }
    
    // --- CAMPAIGNS COLLECTION ---
    match /campaigns/{campaignId} {
      // Public read for active campaigns
      allow read: if true;
      
      // Only super admins can write campaigns
      allow write: if isSuperAdmin();
    }
    
    // --- ADMIN PERMISSIONS COLLECTION ---
    match /adminPermissions/{permissionId} {
      // Only super admins can read/write permissions
      allow read, write: if isSuperAdmin();
    }
    
    // --- SYSTEM NOTIFICATIONS COLLECTION ---
    match /systemNotifications/{notificationId} {
      // Public read for system-wide notifications
      allow read: if true;
      
      // Only super admins can write system notifications
      allow write: if isSuperAdmin();
    }
    
    // --- RESTAURANT COLLECTIONS ---
    // Menü Kategorileri
    match /menuCategories/{categoryId} {
      // Public read (müşteriler görebilir)
      allow read: if true;
      
      // Restoran sahibi kendi kategorilerini yönetebilir
      allow write: if request.auth != null && 
                      (resource == null || isSalonOwner(resource.data.restaurantId));
      
      // Super admins can do anything
      allow read, write: if isSuperAdmin();
    }
    
    // Menü Ürünleri
    match /menuItems/{itemId} {
      // Public read (müşteriler görebilir)
      allow read: if true;
      
      // Restoran sahibi kendi ürünlerini yönetebilir
      allow write: if request.auth != null && 
                      (resource == null || isSalonOwner(resource.data.restaurantId));
      
      // Super admins can do anything
      allow read, write: if isSuperAdmin();
    }
    
    // Masalar
    match /tables/{tableId} {
      // Public read (QR kod ile erişim için)
      allow read: if true;
      
      // Restoran sahibi kendi masalarını yönetebilir
      allow write: if request.auth != null && 
                      (resource == null || isSalonOwner(resource.data.restaurantId));
      
      // Super admins can do anything
      allow read, write: if isSuperAdmin();
    }
    
    // Siparişler
    match /orders/{orderId} {
      // Müşteriler kendi siparişlerini görebilir
      allow read: if true;
      
      // Müşteriler sipariş oluşturabilir
      allow create: if true;
      
      // Restoran sahibi/personeli siparişleri yönetebilir
      allow update: if request.auth != null && isSalonOwner(resource.data.restaurantId);
      
      // Super admins can do anything
      allow read, write: if isSuperAdmin();
    }
    
    // Restoran Bildirimleri
    match /restaurantNotifications/{notificationId} {
      // Herkes okuyabilir (authenticated olmayan garsonlar için)
      allow read: if true;
      
      // Müşteriler bildirim oluşturabilir (garson çağır, hesap iste vb.)
      allow create: if true;
      
      // Herkes güncelleyebilir ve silebilir (authenticated olmayan garsonlar için)
      // TODO: Production'da authentication eklenince kısıtla
      allow update, delete: if true;
      
      // Super admins can do anything
      allow read, write: if isSuperAdmin();
    }
    
    // Restoran Ayarları
    match /restaurantSettings/{restaurantId} {
      // Restoran sahibi kendi ayarlarını okuyabilir
      allow read: if request.auth != null && isSalonOwner(restaurantId);
      
      // Restoran sahibi kendi ayarlarını yönetebilir
      allow write: if request.auth != null && isSalonOwner(restaurantId);
      
      // Super admins can do anything
      allow read, write: if isSuperAdmin();
    }
    
    // Restoran Personeli
    match /restaurantStaff/{staffId} {
      // Restoran sahibi personeli görebilir
      allow read: if request.auth != null && 
                     (resource == null || isSalonOwner(resource.data.restaurantId));
      
      // Restoran sahibi personeli yönetebilir
      allow write: if request.auth != null && 
                      (resource == null || isSalonOwner(resource.data.restaurantId));
      
      // Super admins can do anything
      allow read, write: if isSuperAdmin();
    }
    
    // Default: Deny all other access except super admin
    match /{document=**} {
      allow read, write: if isSuperAdmin();
    }
  }
}
