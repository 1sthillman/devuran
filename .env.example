VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# SECURITY: reCAPTCHA v3 Site Key for Firebase App Check
# Get from: https://console.cloud.google.com/security/recaptcha
VITE_RECAPTCHA_SITE_KEY=your_recaptcha_site_key_here

# Cloudflare R2 Storage Configuration
VITE_R2_ACCESS_KEY_ID=your_r2_access_key_id
VITE_R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
VITE_R2_BUCKET_NAME=devuran-images
VITE_R2_PUBLIC_URL=https://images.devuran.com
VITE_R2_UPLOAD_ENDPOINT=https://api.devuran.com/r2/upload
VITE_R2_DELETE_ENDPOINT=https://api.devuran.com/r2/delete
